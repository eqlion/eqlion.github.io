---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogPreview from '../components/BlogPreview.astro';
import ExperienceEntry from '../components/ExperienceEntry.astro';
import SectionHeader from '../components/SectionHeader.astro';
import {
    contacts,
    education,
    experience,
    profile,
    selectedImpact,
    skills,
} from '../data/resume';

const educationPeriod = `${education.start}–${education.end}`;
const personData = {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: profile.name,
    url: Astro.site,
    jobTitle: profile.headline,
    address: {
        '@type': 'PostalAddress',
        addressLocality: 'Bangkok',
        addressCountry: 'Thailand',
    },
    sameAs: contacts
        .filter(({ url }) => url.startsWith('https://'))
        .map(({ url }) => url),
};
---

<BaseLayout
    title={profile.name}
    description={profile.about[0]}
    structuredData={personData}
>
    <section>
        <header class="section-header">
            <h1>{profile.name}</h1>
            <a href="/blog">blog →</a>
        </header>
        <p><strong>{profile.headline}</strong></p>
        <p class="dim">{profile.location}</p>
    </section>

    <section>
        <SectionHeader title="Contacts && Links" />
        <nav class="contacts" aria-label="Contact links">
            {
                contacts.map((contact) => (
                    <a href={contact.url} target="_blank" rel="noreferrer">
                        {contact.label}
                    </a>
                ))
            }
        </nav>
    </section>

    <section>
        <SectionHeader title="About" />
        {profile.about.map((paragraph) => <p>{paragraph}</p>)}
    </section>

    <section>
        <SectionHeader title="Selected Impact" />
        <ul class="terminal-list">
            {selectedImpact.map((impact) => <li>{impact}</li>)}
        </ul>
    </section>

    <section>
        <SectionHeader title="Experience" />
        {experience.map((entry) => <ExperienceEntry entry={entry} />)}
    </section>

    <BlogPreview />

    <section>
        <SectionHeader title="Education" />
        <article class="experience-entry">
            <div class="company-line">
                <span class="company">{education.institution}</span><span>, </span>
            </div>
            <div class="role-block">
                <strong class="role">{education.position}</strong>
                <span class="dim">({educationPeriod})</span>
            </div>
        </article>
    </section>

    <section>
        <SectionHeader title="Core Skills" />
        <ul class="terminal-list">
            {
                skills.map((skill) => (
                    <li><strong>{skill.title} :: <span>{skill.text}</span></strong></li>
                ))
            }
        </ul>
    </section>
</BaseLayout>
